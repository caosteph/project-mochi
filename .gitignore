# Secrets — NEVER commit
.env

# Local data & agent-built artifacts
data/*
!data/.gitkeep
workspace/*
!workspace/.gitkeep

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# OS
.DS_Store

# DB backups (local rotated pg_dumps) + backup log
backups/*
!backups/.gitkeep
data/backup.log
