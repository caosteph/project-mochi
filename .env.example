# Copy to `.env` and fill in real values. `.env` is git-ignored — never commit it.

# --- Telegram (from @BotFather, and your own chat_id via getUpdates) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Database (Postgres.app, local) ---
DATABASE_URL=postgresql://localhost/personal_agent

# --- Local inference (Ollama, OpenAI-compatible endpoint) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=qwen2.5:7b

# --- Privacy master switch ---
# true = everything runs locally (Phase 0 default and current reality).
# The deterministic local-vs-hosted router arrives in Phase 4; until then keep this true.
LOCAL_ONLY=true
