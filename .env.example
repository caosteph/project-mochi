# Copy to `.env` and fill in real values. `.env` is git-ignored — never commit it.

# --- Telegram (from @BotFather, and your own chat_id via getUpdates) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Database (Postgres.app, local) ---
DATABASE_URL=postgresql://localhost/personal_agent

# --- Local inference (Ollama, OpenAI-compatible endpoint) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
# IMPORTANT: use the 8k-context variant. Ollama's default context is 4096, but a normal turn's
# prompt is already ~3,800-4,050 tokens, leaving ~75 tokens to generate a reply — which forces
# context-shifting mid-generation and silently degrades tool-calling (measured: several prompts
# went 0/4 -> 4/4 just from this). Build it once:
#     ollama create qwen2.5:7b-8k -f ollama/Modelfile.qwen2.5-7b-8k
# (Re-run after re-pulling the base model.) See docs/14-future-work.md for the measurements.
LOCAL_MODEL=qwen2.5:7b-8k

# --- Privacy master switch ---
# true = everything runs locally (the default and current reality). The router honors
# this first: while true, NOTHING goes to the hosted endpoint below, no matter what.
LOCAL_ONLY=true

# --- Opt-in FREE hosted model (Phase 4A) — non-sensitive work only ---
# Used ONLY by the consult_expert tool + /ask, and ONLY for de-identified/generic text
# (a deterministic scrubber redacts known identifiers before anything is sent, and every
# hosted call is logged locally — see /sent). Leave disabled to stay fully local.
# Pick a free, OpenAI-compatible, open-weight endpoint, e.g.:
#   Groq       BASE_URL=https://api.groq.com/openai/v1        MODEL=llama-3.3-70b-versatile
#   OpenRouter BASE_URL=https://openrouter.ai/api/v1          MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Cerebras   BASE_URL=https://api.cerebras.ai/v1            MODEL=llama-3.3-70b
# To go live: set HOSTED_ENABLED=true, LOCAL_ONLY=false, and fill all three fields.
HOSTED_ENABLED=false
HOSTED_BASE_URL=
HOSTED_MODEL=
HOSTED_API_KEY=

# Terms to ALWAYS hard-redact from anything sent to the hosted model (comma-separated:
# your name, email, aliases). The deterministic backstop on top of the model's own
# de-identification. Structural PII (emails/phones/SSNs/cards) is always redacted too.
# NOTE: REDACT_TERMS also scrubs web-search queries below.
REDACT_TERMS=

# --- Web search (Phase 8) — the local model can look things up online ---
# Only a PII-SCRUBBED query leaves; results are read/summarized by the LOCAL model; every
# query is logged (/sent) and asks for your approval before it runs. Independent of
# LOCAL_ONLY. Provider is pluggable:
#   tavily     — best for agents, free tier (~1000/mo). Get a free key at tavily.com and
#                set WEB_SEARCH_API_KEY.
#   duckduckgo — no API key, no signup ($0); thinner results, can rate-limit.
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=
